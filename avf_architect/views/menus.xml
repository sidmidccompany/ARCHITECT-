<odoo>
    <menuitem id="menu_architect_root" name="Architect" sequence="10"/>

    <menuitem id="menu_architect_project" name="Projects" parent="menu_architect_root" action="action_architect_project"/>

    <record id="action_architect_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">architect.project</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_architect_project_tree" model="ir.ui.view">
        <field name="name">architect.project.tree</field>
        <field name="model">architect.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_manager_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </tree>
        </field>
    </record>

    <record id="view_architect_project_form" model="ir.ui.view">
        <field name="name">architect.project.form</field>
        <field name="model">architect.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="project_manager_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <notebook>
                        <page string="Blueprints">
                            <field name="blueprint_ids">
                                <tree>
                                    <field name="name"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                            <field name="file" filename="name"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
